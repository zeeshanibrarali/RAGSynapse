# RAGSynapse v2 - Production Multi-LLM RAG (0.87 faithfulness score)
# Copy to .env and add your API keys

OPENAI_API_KEY=                    # REQUIRED: sk-... 
LLM_PROVIDER=openai                # openai | anthropic | ollama
ANTHROPIC_API_KEY=                 # OPTIONAL: for Claude 3.5 Sonnet
OLLAMA_BASE_URL=http://localhost:11434  # OPTIONAL: local Llama3

# Redis (Docker auto-config)
REDIS_HOST=redis
REDIS_PORT=6379

# MLflow tracking
MLFLOW_TRACKING_URI=http://localhost:5000
